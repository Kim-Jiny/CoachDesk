{
  "name": "coachdesk-server",
  "version": "1.0.0",
  "description": "CoachDesk API Server",
  "main": "dist/index.js",
  "scripts": {
    "db:prepare": "npm run prisma:generate && npm run prisma:migrate",
    "dev": "npm run db:prepare && ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "npm run prisma:generate && tsc",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "start": "npm run db:prepare && node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "firebase-admin": "^13.7.0",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.2",
    "minio": "^8.0.5",
    "morgan": "^1.10.0",
    "socket.io": "^4.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.13.10",
    "prisma": "^6.5.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.2"
  }
}
