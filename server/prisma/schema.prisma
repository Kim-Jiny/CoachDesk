generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Organization (센터) ───────────────────────────────────
model Organization {
  id                 String            @id @default(uuid())
  name               String
  description        String?
  logoUrl            String?
  reservationNoticeText String?
  reservationNoticeImageUrl String?
  reservationOpenDaysBefore Int        @default(30)
  reservationOpenHoursBefore Int       @default(0)
  reservationCancelDeadlineMinutes Int @default(120)
  inviteCode         String            @unique
  bookingMode        BookingMode       @default(PRIVATE)
  reservationPolicy  ReservationPolicy @default(AUTO_CONFIRM)
  planType           PlanType          @default(FREE)
  maxAdminCount      Int               @default(2)
  maxMemberCount     Int               @default(30)
  planExpiresAt      DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  memberships OrgMembership[]
  memberGroups MemberGroup[]
  members     Member[]
  schedules   Schedule[]
  scheduleOverrides ScheduleOverride[]
  reservations Reservation[]
  packages    Package[]
  sessions    Session[]
  notifications Notification[]
  chatRooms     ChatRoom[]
  centerJoinRequests CenterJoinRequest[]
}

enum BookingMode {
  PRIVATE
  PUBLIC
}

enum ReservationPolicy {
  AUTO_CONFIRM
  REQUEST_APPROVAL
}

// ─── User (Coach / Admin) ──────────────────────────────────
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  name         String
  phone        String?
  profileImage String?
  fcmToken     String?
  notificationPreferences String?
  googleId     String?  @unique
  appleId      String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships   OrgMembership[]
  schedules     Schedule[]
  scheduleOverrides ScheduleOverride[]
  reservations  Reservation[]    @relation("coachReservations")
  sessions      Session[]        @relation("coachSessions")
  notifications Notification[]
  chatRooms     ChatRoom[]
  centerJoinRequests CenterJoinRequest[]
}

// ─── OrgMembership (User ↔ Org) ───────────────────────────
model OrgMembership {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           OrgRole  @default(STAFF)
  createdAt      DateTime @default(now())

  @@unique([userId, organizationId])
}

enum OrgRole {
  OWNER
  MANAGER
  STAFF
  VIEWER
}

// ─── CenterJoinRequest (센터 합류 신청) ────────────────────
model CenterJoinRequest {
  id             String            @id @default(uuid())
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  status         JoinRequestStatus @default(PENDING)
  message        String?
  reviewedBy     String?
  reviewedAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([userId, organizationId, status])
  @@index([organizationId, status])
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PlanType {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

model MemberGroup {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  members        Member[]

  @@index([organizationId, sortOrder])
}

// ─── Member (고객) ─────────────────────────────────────────
model Member {
  id              String       @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberGroupId   String?
  memberGroup     MemberGroup? @relation(fields: [memberGroupId], references: [id], onDelete: SetNull)
  name            String
  phone           String?
  email           String?
  birthDate       DateTime?
  gender          Gender?
  memo            String?
  status          MemberStatus @default(ACTIVE)
  memberAccountId String?
  memberAccount   MemberAccount? @relation(fields: [memberAccountId], references: [id])
  sortOrder       Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  reservations    Reservation[]
  memberPackages  MemberPackage[]
  sessions        Session[]      @relation("memberSessions")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

// ─── MemberAccount (공개예약 로그인용) ─────────────────────
model MemberAccount {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  fcmToken  String?
  notificationPreferences String?
  googleId  String?  @unique
  appleId   String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   Member[]
  chatRooms ChatRoom[]
}

// ─── Schedule (코치 가용 시간 템플릿) ──────────────────────
model Schedule {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  coachId        String
  coach          User         @relation(fields: [coachId], references: [id], onDelete: Cascade)
  dayOfWeek      Int          // 0=Sunday, 6=Saturday
  startTime      String       // "09:00"
  endTime        String       // "10:00"
  slotDuration   Int          @default(60) // minutes
  breakMinutes   Int          @default(0)
  maxCapacity    Int          @default(1)
  isPublic       Boolean      @default(false)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// ─── ScheduleOverride (특정 날짜 추가/제외) ─────────────────
model ScheduleOverride {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  coachId        String
  coach          User         @relation(fields: [coachId], references: [id], onDelete: Cascade)
  date           DateTime     @db.Date
  type           OverrideType
  startTime      String?      // OPEN일 때만
  endTime        String?
  slotDuration   Int?
  breakMinutes   Int?
  maxCapacity    Int?
  isPublic       Boolean?
  createdAt      DateTime     @default(now())

  @@index([organizationId, date])
  @@index([coachId, date])
}

enum OverrideType {
  OPEN
  CLOSED
  VISIBLE
  HIDDEN
}

// ─── Reservation (예약) ────────────────────────────────────
model Reservation {
  id             String            @id @default(uuid())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  coachId        String
  coach          User              @relation("coachReservations", fields: [coachId], references: [id], onDelete: Cascade)
  memberId       String
  member         Member            @relation(fields: [memberId], references: [id], onDelete: Cascade)
  date           DateTime          @db.Date
  startTime      String            // "09:00"
  endTime        String            // "10:00"
  status         ReservationStatus @default(PENDING)
  memo           String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  session        Session?
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ─── Package (패키지 템플릿) ───────────────────────────────
model Package {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  totalSessions  Int
  price          Int          // KRW
  validDays      Int?         // null = unlimited
  isActive       Boolean      @default(true)
  isPublic       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  memberPackages MemberPackage[]
}

// ─── MemberPackage (회원에 할당된 패키지) ──────────────────
model MemberPackage {
  id                String              @id @default(uuid())
  memberId          String
  member            Member              @relation(fields: [memberId], references: [id], onDelete: Cascade)
  packageId         String
  package           Package             @relation(fields: [packageId], references: [id])
  totalSessions     Int
  usedSessions      Int                 @default(0)
  remainingSessions Int
  purchaseDate      DateTime            @default(now())
  expiryDate        DateTime?
  paidAmount        Int
  paymentMethod     PaymentMethod       @default(CASH)
  status            MemberPackageStatus @default(ACTIVE)
  pauseStartDate    DateTime?           @db.Date
  pauseEndDate      DateTime?           @db.Date
  pauseRequestedStartDate DateTime?     @db.Date
  pauseRequestedEndDate   DateTime?     @db.Date
  pauseRequestStatus PauseRequestStatus @default(NONE)
  pauseRequestReason String?
  pauseExtensionDays Int                @default(0)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  sessions          Session[]
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

enum MemberPackageStatus {
  ACTIVE
  EXPIRED
  EXHAUSTED
  REFUNDED
}

enum PauseRequestStatus {
  NONE
  PENDING
}

// ─── Session (완료된 세션 기록) ────────────────────────────
model Session {
  id              String       @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reservationId   String       @unique
  reservation     Reservation  @relation(fields: [reservationId], references: [id])
  coachId         String
  coach           User         @relation("coachSessions", fields: [coachId], references: [id])
  memberId        String
  member          Member       @relation("memberSessions", fields: [memberId], references: [id])
  memberPackageId String?
  memberPackage   MemberPackage? @relation(fields: [memberPackageId], references: [id])
  date            DateTime     @db.Date
  attendance      Attendance   @default(PRESENT)
  memo            String?
  workoutRecords  Json?
  feedback        String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

enum Attendance {
  PRESENT
  NO_SHOW
  LATE
  CANCELLED
}

// ─── Notification ──────────────────────────────────────────
model Notification {
  id             String       @id @default(uuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           String
  title          String
  body           String
  data           Json?
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

// ─── ChatRoom (1:1 채팅방) ───────────────────────────────
model ChatRoom {
  id              String        @id @default(uuid())
  organizationId  String
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  memberAccountId String
  memberAccount   MemberAccount @relation(fields: [memberAccountId], references: [id], onDelete: Cascade)
  lastMessageAt   DateTime?
  createdAt       DateTime      @default(now())

  messages        ChatMessage[]

  @@unique([organizationId, userId, memberAccountId])
  @@index([userId, lastMessageAt])
  @@index([memberAccountId, lastMessageAt])
}

// ─── ChatMessage (채팅 메시지) ────────────────────────────
model ChatMessage {
  id          String      @id @default(uuid())
  chatRoomId  String
  chatRoom    ChatRoom    @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  senderType  SenderType
  senderId    String
  content     String
  messageType MessageType @default(TEXT)
  isRead      Boolean     @default(false)
  createdAt   DateTime    @default(now())

  @@index([chatRoomId, createdAt])
  @@index([chatRoomId, isRead])
}

enum SenderType {
  USER
  MEMBER
}

enum MessageType {
  TEXT
  IMAGE
  SYSTEM
}
